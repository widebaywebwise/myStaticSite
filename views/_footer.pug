footer 

	.footer
	
		.footer--box
	
		
			.footer--logo-box
			
				.footer--logo-box--text
					a(href="/") 
						img(src='/img/logo/myLogo-footer.webp', alt='image', class='header__logo' , loading="lazy")
					.footer-text-p
						p Custom-coded websites for local businesses in the Wide Bay region.
						p Built for flexibility, performance, and long-term support.
				.footer--copyright
					p &copy; 2026 Widebay Web Wise.
			
			.footer--services-box
				p.footer--box-heading Services 
				ul 
					li One-Page Websites
					li Multi-Page Websites
					li Advanced Websites
					li Ongoing Support
				
			.footer--links-box
				p.footer--box-heading Quick Links
				ul 
					li 
						a(href='/' class='') Home
					li 
						a(href='/static/services' class='') Services
					li 
						a(href='/static/about' class='') About
					li 
						a(href='/static/contact' class='') Contact
			
				
			.footer--contact-box
				p.footer--box-heading Contact 
				
				.footer--contact-box-details
					ul 
						li Bundaberg / Wide Bay, QLD
						li 
							a(href="mailto:hello@widebaywebwise.com.au") Email: hello@widebaywebwise.com.au
						li 
							a(href="tel:+61452210276") Phone: 0452210276
						
				.footer--contact-box-socials
					ul.socials-box 
						li
							a(href='https://www.facebook.com/widebaywebwise' target='_blank' rel='noopener noreferrer') 
								img(src="/img/icons/socials/facebook-icon.svg", alt="")
						li
							a(href='https://m.me/widebaywebwise' target='_blank' rel='noopener noreferrer')
								img(src="/img/icons/socials/messenger-logo.svg", alt="")
						li
							a(href='https://wa.me/61452210276' target='_blank' rel='noopener noreferrer')
								img(src="/img/icons/socials/whatsapp-logo.svg", alt="")
						li
							a(href='https://maps.app.goo.gl/DR99pyCeaLCZMzXR7' target='_blank' rel='noopener noreferrer')
								img(src="/img/icons/socials/google-logo.svg", alt="")
