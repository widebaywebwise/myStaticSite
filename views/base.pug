doctype html 

html(lang="en") 
	head
		if process.env.NODE_ENV === 'production' && gaMeasurementId
			script(async src=`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`)
			script.
				window.dataLayer = window.dataLayer || [];
				function gtag(){dataLayer.push(arguments);}
				gtag('js', new Date());
				gtag('config', '#{gaMeasurementId}');
		
		//-- Google Tag Manager - do later (early load)		
		
		meta(charset='UTF-8')
		meta(name='viewport' content='width=device-width, initial-scale=1.0')
		meta(name='description' content=pageDescription || 'Custom web design and development for local businesses in Bundaberg, Hervey Bay, Maryborough and across the Wide Bay region. Fast, professional websites built from scratch.')
		
		
		if noIndex
			meta(name="robots" content="noindex, nofollow")
		else
			meta(name="robots" content="index, follow")
			link(rel="canonical" href=canonicalUrl)
		
		//-- Open Graph
		
		meta(property="og:type" content="website")
		meta(property="og:site_name" content="Widebay Web Wise")
		meta(property="og:image:type" content="image/png")
		meta(property="og:image" content="https://www.widebaywebwise.com.au/img/logo/og-logo.png")
		meta(property="og:image:width" content="1200")
		meta(property="og:image:height" content="630")
		
		if noIndex
			meta(property="og:title" content=pageTitle)
			meta(property="og:description" content=pageDescription)
		else
			meta(property="og:url" content=canonicalUrl)
			meta(property="og:title" content=pageTitle)
			meta(property="og:description" content=pageDescription)
		
		
		link(rel='stylesheet', href='/css/style.css?v=1.49')
		
	
		
		//-- Preconnects (speed up external resources)
		
		link(rel="preload" href="/img/fonts/rubik/Rubik-SemiBold.woff2" as="font" type="font/woff2" crossorigin="anonymous")
		link(rel="preload" href="/img/fonts/poppins/Poppins-Regular.woff2" as="font" type="font/woff2" crossorigin="anonymous")
		
		
		
		
		//-- Preloads (critical assets)		
		
			
		
		link(rel='shortcut icon' type='image/png'  sizes="180x180"  href=favicon || '/img/favicons/favicon.png')
		
		title= pageTitle || 'Wide Bay Web Designer & Developer | Widebay Web Wise'
		
		script(type="application/ld+json").
			{
				"@context": "https://schema.org",
				"@type": "ProfessionalService",
				"name": "Widebay Web Wise",
				"description": "Custom-built websites for local businesses across the Wide Bay region, including Bundaberg, Hervey Bay, and Maryborough.",
				"url": "https://www.widebaywebwise.com.au",
				"telephone": "+61452210276",
				"email": "hello@widebaywebwise.com.au",
				"address": {
				  "@type": "PostalAddress",
				  "addressLocality": "Bundaberg",
				  "addressRegion": "QLD",
				  "addressCountry": "AU"
				},
				"openingHoursSpecification": [
			  {
			    "@type": "OpeningHoursSpecification",
			    "dayOfWeek": [
			      "Monday",
			      "Tuesday",
			      "Wednesday",
			      "Thursday",
			      "Friday"
			    ],
			    "opens": "08:30",
			    "closes": "19:00"
			  },
			  {
			    "@type": "OpeningHoursSpecification",
			    "dayOfWeek": "Saturday",
			    "opens": "09:00",
			    "closes": "17:00"
			  },
			  {
			    "@type": "OpeningHoursSpecification",
			    "dayOfWeek": "Sunday",
			    "opens": "10:00",
			    "closes": "15:00"
			  }
			],
			"areaServed": [
				{
					"@type": "City",
					"name": "Bundaberg"
				},
				{
					"@type": "City",
					"name": "Hervey Bay"
				},
				{
					"@type": "City",
					"name": "Maryborough"
				},
				{
					"@type": "AdministrativeArea",
					"name": "Wide Bay"
				}
			],
				"serviceType": "Web Design and Development"
			}
		
	
		
		
	body
		// Header
		include _header
		
		
		// Content
		.tailwind_stretch
			block content
				h1 Placeholder in Base
		
		// Footer
		include _footer

		

		script(defer src='/js/bundle.js')
		

		
