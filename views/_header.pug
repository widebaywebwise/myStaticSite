header 

	.header
		.header--box
	
			.header__logo--box

				a(href="/") 
					img(src='/img/logo/newLogo.webp', alt='Widebay Web Wise logo', class='header__logo' fetchpriority="high")
			
			.header__nav--box
			
				nav.header__nav 
					ul.header__nav--list 
						li.header__nav--item 
							a(href='/static/services' class='header__nav--link') Services
						li.header__nav--item 
							a(href='/static/about' class='header__nav--link') About
						li.header__nav--item 
							a(href='/static/contact' class='header__nav--link') Contact
					
			.header__cta--box
				.header__cta--link-box 
					a(href="/static/contact" class='header__cta-link') Get in Touch ▶
			
			.header__hamburger--box
				button.header__hamburger(type="button" aria-label="Open navigation menu" aria-expanded="false")
					img(src="/img/icons/white-list.svg", class='header__hamburger--icon' alt='')

