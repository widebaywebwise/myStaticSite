
extends base

block content 

	main.container
	
		section.aboutPage
		
			.aboutPage-heading--grid
			
				.aboutPage-heading--box

					h1.aboutPage-heading About Widebay Web Wise
					
					h2.aboutPage-sub-heading
						| Simple, Professional Websites Built for 
						span Local Businesses.
											
					.aboutPage-heading--box--text
					
						p Widebay Web Wise is a web development business based in the Wide Bay region, created to help local businesses get a professional website without feeling overwhelmed by tech, jargon, or one-size-fits-all solutions.
						
						p We build custom websites from scratch, and we keep things plain-spoken and practical — before, during, and after launch.
						
					.aboutPage-list--box
						ul.aboutPage-list--box--list
							li 
								img(src="/img/icons/wrench.svg", class='about-icon', fetchpriority='high', alt="wrench icon")
								strong Custom-built &nbsp; 
								span.aboutList-remove  for your business
							li 
								img(src="/img/icons/device-mobile.svg",  class='about-icon', fetchpriority='high',  alt="mobile phone icon")
								strong Mobile-friendly &nbsp;
								span.aboutList-remove  and modern
							li 
								img(src="/img/icons/local.svg",  class='about-icon', fetchpriority='high',  alt="map pin icon")
								strong Wide Bay local &nbsp;
								span.aboutList-remove - Bundaberg based, easy to reach
							li 
								img(src="/img/icons/headset.svg",  class='about-icon', fetchpriority='high',  alt="headset icon")
								strong Ongoing support &nbsp;
								span.aboutList-remove - before and after launch

							
				.aboutPage-image--box
				
					.aboutPage-image--box--1
					
						img(src="/img/imgs/myImg.webp", class='aboutPage--img' ,alt="wide bay web wise worker building a web site", fetchpriority='high')

					
		section.portfolio
		 
			.portfolio-heading--box
			
				h3.portfolio-heading Recent Projects
				hr.projects-underline
				p A selection of live builds and current projects.
				
			.portfolio-grid
			
			
				.portfolio-site--featured.portfolio-card--grid
				
					.portfolio--text-box-featured
					
						.portfolio--text-box-header
						
							.portfolio--heading-badge
								h4 MyGametrics
								
								.portfolio--status-badge 
									p Live
									
							.portfolio--tags 
								p Dynamic · Ratings · Database
								
						p.portfolio-display--none A custom-built, database-driven game ratings platform where users rate games and contribute to overall scores across Steam titles.
						
						.porfolio-list--box
							//- h4.portfolio--features-heading Features:
							.portfolio-list--cta
								ul.portfolio--skills-list 
									li.portfolio--skills-list-item 
										img(src="/img/icons/check-orange.svg", class='tick-icon' alt="orange tick icon")
										span User accounts and authentication
									li.portfolio--skills-list-item 
										img(src="/img/icons/check-orange.svg", class='tick-icon' alt="orange tick icon")
										span Ratings and leaderboard features
									li.portfolio--skills-list-item 
										img(src="/img/icons/check-orange.svg", class='tick-icon' alt="orange tick icon")
										span Dynamic game data from a database

								.portfolio--featured--link 
									a(href="https://www.mygametrics.com/")  Visit site
					
					.portfolio--image-box-featured
						img(src="/img/imgs/portfolio-feature.webp", alt="mygametrics website example", class='portfolio-featured--img' , loading='lazy')
						
						
				
				.portfolio-site-secondary--left.portfolio-site--card
				
					.portfolio--image-box-secondary
						img(src="/img/imgs/my-website-portfolio.webp", alt="widebay web wise website example", class='portfolio-secondary--img', loading='lazy')
					
					.portfolio--text-box-secondary
					
						.portfolio--text-box-heading 						
							h4 Widebay Web Wise
							.portfolio--status-badge-secondary 
								p Live
							
						
						.portfolio--tags-secondary 
							p Static · Contact Form · Responsive

						.portfolio--featured--link-secondary
							a(href="https://widebaywebwise.com.au")  Visit site
					
				
				.portfolio-site-secondary--middle.portfolio-site--card
				
					.portfolio--image-box-secondary
						img(src="/img/imgs/ang-hiyas-portfolio.webp", alt="ang hiyas barong clothing website example", class='portfolio-secondary--img' loading='lazy')
					
					.portfolio--text-box-secondary
					
						.portfolio--text-box-heading 						
							h4 Ang Hiyas
							.portfolio--status-badge-secondary-building 
								p In Progress
							
							
						.portfolio--tags-secondary 
							p Dynamic · E-commerce · Database 

						.portfolio--featured--link-secondary
							a(href="#")  Visit site
					
					
				.portfolio-site-secondary--right.portfolio-site--card
				
					.portfolio--image-box-secondary
						img(src="/img/imgs/default.jpg", alt="Website example", class='portfolio-secondary--img' , loading='lazy')
					
					.portfolio--text-box-secondary
					
						.portfolio--text-box-heading 						
							h4 Funt T-shirts
							.portfolio--status-badge-secondary-soon 
								p Coming Soon
							
						
						.portfolio--tags-secondary 
							p Dynamic · E-commerce · Database 

						.portfolio--featured--link-secondary
							a(href="#")  Visit site
					
				
				