
extends base

block content 

	main.container
	
		section.aboutPage
		
			.aboutPage-heading--grid
			
				.aboutPage-heading--box

					h2.aboutPage-heading About Widebay Web Wise
					
					h3.aboutPage-sub-heading
						| Simple, Professional Websites Built for 
						span Local Businesses.
											
					.aboutPage-heading--box--text
						p  Widebay Web Wise exists because too many good local businesses are either hard to find online or stuck with a website that no longer reflects the quality of what they do. We help change that with websites built around real business needs.
						
						p Every site we build is custom coded from scratch. No WordPress, no templates, no page builders. Just clean, fast, professional websites built around what your business actually needs — and built to show up on Google.
						
						p We keep things simple, plain-spoken, and practical. No tech jargon, no lock-in contracts, and no disappearing after launch.
						
					.aboutPage-list--box
						ul.aboutPage-list--box--list
							li 
								img(src="/img/icons/wrench.svg", class='about-icon' alt="")
								strong Custom-built &nbsp; 
								| for your business
							li 
								img(src="/img/icons/device-mobile.svg",  class='about-icon'  alt="")
								strong Mobile-friendly &nbsp;
								| and modern
							li 
								img(src="/img/icons/local.svg",  class='about-icon'  alt="")
								strong Wide Bay local &nbsp;
								|- Bundaberg based, easy to reach
							li 
								img(src="/img/icons/headset.svg",  class='about-icon'  alt="")
								strong Ongoing support &nbsp;
								|— before and after launch

							
				.aboutPage-image--box
					.aboutPage-image--box--1
						img(src="/img/imgs/myImg.jpg", class='aboutPage--img' ,alt="")
					.aboutPage-image--box--2
						img(src="/img/imgs/inset-1.svg", class='aboutPage--img-2' alt="")
					
		section.portfolio
		 
			.portfolio-heading--box
			
				h2.section-heading Projects
				
			.portfolio-grid
			
			
				.portfolio-site--featured.portfolio-card--grid
				
					.portfolio--text-box-featured
					
						.portfolio--text-box-header
						
							.portfolio--heading-badge
								h4 MyGametrics
								
								.portfolio--status-badge 
									p Live
									
							.portfolio--tags 
								p Custom coded · Ratings system · Database driven
								
						p A custom-built, database-driven game ratings platform where users create accounts, rate games, and contribute to overall scores across Steam titles.
						
						.porfolio-list--box
							h4.portfolio--features-heading Features:
							ul.portfolio--skills-list 
								li.portfolio--skills-list-item 
									img(src="/img/icons/check-orange.svg", class='tick-icon' alt="")
									span User accounts and authentication
								li.portfolio--skills-list-item 
									img(src="/img/icons/check-orange.svg", class='tick-icon' alt="")
									span Ratings and leaderboard features
								li.portfolio--skills-list-item 
									img(src="/img/icons/check-orange.svg", class='tick-icon' alt="")
									span Dynamic game data from a database

						.portfolio--featured--link 
							a(href="https://www.mygametrics.com/")  Visit site
					
					.portfolio--image-box-featured
						img(src="/img/imgs/portfolio-feature.png", alt="", class='portfolio-featured--img')
						
						
				
				.portfolio-site-secondary--left.portfolio-site--card
				
					.portfolio--image-box-secondary
						img(src="/img/imgs/my-website-portfolio.png", alt="", class='portfolio-secondary--img')
					
					.portfolio--text-box-secondary
					
						.portfolio--text-box-heading 						
							h4 Widebay Web Wise
							.portfolio--status-badge-secondary 
								p Live
							
						.portfolio--text-box-description 
						
							p A custom-built business website promoting web development services for local businesses with a clear, modern user journey.
							
						.portfolio--tags-secondary 
							p Service Website · Contact Form · Responsive Layout

						.portfolio--featured--link-secondary
							a(href="#")  Visit site
					
				
				.portfolio-site-secondary--middle.portfolio-site--card
				
					.portfolio--image-box-secondary
						img(src="/img/imgs/ang-hiyas-portfolio.png", alt="", class='portfolio-secondary--img')
					
					.portfolio--text-box-secondary
					
						.portfolio--text-box-heading 						
							h4 Ang Hiyas
							.portfolio--status-badge-secondary-building 
								p In Progress
							
						.portfolio--text-box-description 
						
							p A custom-built formalwear website, designed to showcase niche products, for a polished eCommerce-style browsing experience.
							
						.portfolio--tags-secondary 
							p Custom coded · E-commerce · Database driven

						.portfolio--featured--link-secondary
							a(href="#")  Visit site
					
					
				.portfolio-site-secondary--right.portfolio-site--card
				
					.portfolio--image-box-secondary
						img(src="/img/imgs/default.jpg", alt="", class='portfolio-secondary--img')
					
					.portfolio--text-box-secondary
					
						.portfolio--text-box-heading 						
							h4 Funt T-shirts
							.portfolio--status-badge-secondary-building 
								p In Progress
							
						.portfolio--text-box-description 
						
							p A custom-built e-commerce website for printed designed t-shirts. Exercitationem ad fuga ratione commodi atque consequuntur doloribus fugiat!
							
						.portfolio--tags-secondary 
							p Custom coded · E-commerce · Database driven

						.portfolio--featured--link-secondary
							a(href="#")  Visit site
					
				
				