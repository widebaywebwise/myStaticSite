						p Widebay Web Wise is a Bundaberg-based web design business focused on creating practical, custom websites for local businesses across the Wide Bay region.

						p Clear communication, straightforward support, and websites built around each business are a key part of how we work.
						
						p We are here for local businesses that want a professional website without the confusion, pressure, or overcomplicated agency approach.
						
					.aboutPage-image--box
					
						.aboutPage-image--box--1
						
							img(src="/img/imgs/myImg-mobile.webp", class='aboutPage--img' ,alt="wide bay web wise worker building a web site")
							
					.aboutPage-list--box
						ul.aboutPage-list--box--list
							li 
								img(src="/img/icons/gear.svg", class='about-icon', alt="wrench icon")
								strong Practical approach &nbsp; 
								span.aboutList-remove to web design

							li 
								img(src="/img/icons/chat.svg", class='about-icon', alt="mobile phone icon")
								strong Clear communication &nbsp;
								span.aboutList-remove throughout the process

							li 
								img(src="/img/icons/local.svg", class='about-icon', alt="map pin icon")
								strong Bundaberg based &nbsp;
								span.aboutList-remove and approachable

							li 
								img(src="/img/icons/headset.svg", class='about-icon', alt="headset icon")
								strong Ongoing Support &nbsp;
								span.aboutList-remove before and after launch

							
					
					
		section.portfolio
		 
			.portfolio-heading--box
			
				h3.portfolio-heading.section__heading-underline Recent Projects
			
				p A look at recent website builds and current projects.
				
			.portfolio-grid
			
			
				.portfolio-site-secondary--left.portfolio-site--card
				
					.portfolio--image-box-secondary
						img(src="/img/imgs/portfolio-feature.webp", alt="Screenshot of the MyGametrics website homepage", class='portfolio-secondary--img' , loading='lazy')
					
					.portfolio--text-box-secondary
					
						.portfolio--text-box-header
						
							.portfolio--heading-badge
								h4 MyGametrics
								
								.portfolio--status-badge.portfolio--status-badge--live 
									p Live
									
							.portfolio--tags 
								p Dynamic · Ratings · Database
								
					
						
	
						.portfolio--featured--link 
							a(href="https://www.mygametrics.com/")  Visit site →
					
						
						
		
			
				.portfolio-site-secondary--left.portfolio-site--card
				
					.portfolio--image-box-secondary
						img(src="/img/imgs/ang-hiyas-portfolio.webp", alt="Screenshot of the Ang Hiyas website homepage", class='portfolio-secondary--img' , loading='lazy')
					
					.portfolio--text-box-secondary
					
						.portfolio--text-box-header
						
							.portfolio--heading-badge
								h4 Ang Hiyas
								
								.portfolio--status-badge.portfolio--status-badge--dev 
