
extends base

block content 

	main.container.aboutPage-container
	
		section.aboutPage
		
			.aboutPage-heading--grid
			
				.aboutPage-heading--box
					h1.aboutPage-heading About Widebay Web Wise

					h2.aboutPage-sub-heading
						| Practical Websites,
						.break
							span  Clear Communication
	

											
					.aboutPage-heading--box--text
					
						p Widebay Web Wise is a Bundaberg-based web design business focused on creating practical, custom websites for local businesses across the Wide Bay region.

						p Clear communication, straightforward support, and websites built around each business are a key part of how we work.
						
						p We are here for local businesses that want a professional website without the confusion, pressure, or overcomplicated agency approach.
						
					.aboutPage-list--box
						ul.aboutPage-list--box--list
							li 
								img(src="/img/icons/gear.svg", class='about-icon', alt="wrench icon")
								strong Practical approach &nbsp; 
								span.aboutList-remove to web design

							li 
								img(src="/img/icons/chat.svg", class='about-icon', alt="mobile phone icon")
								strong Clear communication &nbsp;
								span.aboutList-remove throughout the process

							li 
								img(src="/img/icons/local.svg", class='about-icon', alt="map pin icon")
								strong Bundaberg based &nbsp;
								span.aboutList-remove and approachable

							li 
								img(src="/img/icons/headset.svg", class='about-icon', alt="headset icon")
								strong Ongoing Support &nbsp;
								span.aboutList-remove before and after launch

							
				.aboutPage-image--box
				
					.aboutPage-image--box--1
					
						img(src="/img/imgs/myImg.webp", class='aboutPage--img' ,alt="wide bay web wise worker building a web site")
			
			
			.aboutPage-heading--grid-mobile
			
				.aboutPage-heading--box

					h1.aboutPage-heading About Widebay Web Wise
					
					h2.aboutPage-sub-heading
						| Practical Websites,
						.break
							span Clear Communication
											
