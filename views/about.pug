								p Dynamic · E-commerce · Database
								
					
						
	
						.portfolio--featured--link 
							a(href="https://barong-website.onrender.com/")   Visit site →
					
						
		
			
				.portfolio-site-secondary--left.portfolio-site--card
				
					.portfolio--image-box-secondary
						img(src="/img/imgs/widebay.webp", alt="Screenshot of the Widebay Web Wise website homepage", class='portfolio-secondary--img' , loading='lazy')
					
					.portfolio--text-box-secondary
					
						.portfolio--text-box-header
						
							.portfolio--heading-badge
								h4 Widebay Web Wise
								
								.portfolio--status-badge.portfolio--status-badge--live 
									p Live
									
							.portfolio--tags 
								p  Service · SEO · Contact Form
								
				
						
	
						.portfolio--featured--link 
							a(href="https://widebaywebwise.com.au") Visit site →
					
		
			
				.portfolio-site-secondary--left.portfolio-site--card
				
					.portfolio--image-box-secondary
						img(src="/img/imgs/default.webp", alt="Preview image for the Funt Tees website project", class='portfolio-secondary--img' , loading='lazy')
					
					.portfolio--text-box-secondary
					
						.portfolio--text-box-header
						
							.portfolio--heading-badge
								h4 Funt Tees
								
