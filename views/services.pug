
extends base

block content 

	main.servicesPage-block
	
		section.servicesPage
			
			.servicesPage-heading-box.container
			
				.servicesPage-heading-box-underline

					h1.servicesPage--heading.section__heading-underline Services
				
				p Custom websites for different business needs, from a simple online presence to more tailored website functionality.

				
			
		section.servicesPage-boxes.container
		
			.servicePage--grid
		
				.servicePage--box
			
					.servicePage--box-heading--box
						.servicePage--box-heading--icon
							img(src="/img/icons/scroll.svg" class="servicesPage-icon" alt="scroll icon" )
						.servicePage--box-heading--text
							h3.servicePage--box-heading Starter Website

					.servicePage--box-details--box
						p.servicePage--box-details For small businesses that need a professional online presence without extra complexity.
						
						.servicePage--box-includes--box
						
							ul.servicePage--box-includes
								li Clear contact and enquiry options
								li Services and service area clearly presented
								li Designed to work well on phones
								
							.servicePage--included-btn--box 
								button.servicePage-included-btn(type='button') See what’s included?

					.servicePage-included--box.box--inactive
						.servicePage-included--heading-box
							h3.servicePage-included--heading Starter Website
							.servicePage-included--close 
								button.servicePage-included-close(type='button' aria-label='Close included features') 
									p ×
							
						.servicePage-included--text
							p.servicePage-included--details For small businesses that need a professional online presence without extra complexity.
		
						
						.servicePage-included--list
							p May include:
							ul.servicePage-included--ul
									li Contact form
									li Click-to-call button
									li Services section
									li Service area section
									li About or business intro
									li Mobile-friendly layout	
			
				.servicePage--box
			
					.servicePage--box-heading--box
						.servicePage--box-heading--icon
							img(src="/img/icons/files.svg" class="servicesPage-icon" alt="files icon" )
						.servicePage--box-heading--text
							h3.servicePage--box-heading Service Website

					.servicePage--box-details--box
						p.servicePage--box-details For businesses that offer multiple services and want a stronger, more informative website.
						.servicePage--box-includes--box
							ul.servicePage--box-includes
								li Separate pages for each service
								li More room for trust-building pages
								li Stronger support for search visibility
								
							.servicePage--included-btn--box 
								button.servicePage-included-btn(type='button') See what’s included?
	
					.servicePage-included--box.box--inactive
						.servicePage-included--heading-box
							h3.servicePage-included--heading Service Website
							.servicePage-included--close 
								button.servicePage-included-close(type='button' aria-label='Close included features') 
									p ×
						.servicePage-included--text
							p.servicePage-included--details For businesses that offer multiple services and want a stronger, more informative website.
		
						
						.servicePage-included--list
							p May include:
							ul.servicePage-included--ul
									li Separate pages for each service
									li A stronger About page
									li FAQ or trust-building pages
									li Clear, easy site navigation
									li A dedicated Contact page
									li Gallery or portfolio page
									li A better structure for search visibility
			
				
				.servicePage--box
		
					.servicePage--box-heading--box
						.servicePage--box-heading--icon
							img(src="/img/icons/database.svg" class="servicesPage-icon" alt="database icon" )
						.servicePage--box-heading--text
							h3.servicePage--box-heading Custom Website

					.servicePage--box-details--box
						p.servicePage--box-details For businesses that require tailored functionality, flexible content, or custom-built features.
						.servicePage--box-includes--box
							ul.servicePage--box-includes
								li Add and update your own content
								li Secure handling of sensitive information
								li Features built around your business needs					
									
							.servicePage--included-btn--box 
								button.servicePage-included-btn(type='button') See what’s included?
							
					.servicePage-included--box.box--inactive
						.servicePage-included--heading-box
							h3.servicePage-included--heading Custom Website	
							.servicePage-included--close 
								button.servicePage-included-close(type='button' aria-label='Close included features') 
									p ×
						.servicePage-included--text
							p.servicePage-included--details For businesses that need more tailored functionality, flexible content, or custom-built features.
				
						
						.servicePage-included--list
							p May include:		
							ul.servicePage-included--ul
									li Admin-managed content
									li User accounts or logins
									li Search or filter tools
									li Booking or request systems
									li Interactive user features
									li Saved enquiries or submissions
									li Custom-built functionality

		
		section.servicesPage-cta.container
			.servicesPage--link
				.servicesPage--link-pricing
					p.servicesPage--link-p Every business is different, so each custom-built website is quoted around the features and functionality you actually need.
				p.servicesPage--reassurance Not sure which option suits your business? We can help you choose the right fit.
			
			
				a.banner-cta(href="/static/contact") Request a Quote ▶