
extends base

block content 

	main.servicesPage-block
	
		section.servicesPage
			
			.servicesPage-heading-box.container
			
				.servicesPage-heading-box-underline

					h1.servicesPage--heading.section__heading-underline Services
				
				p Clean, fast websites built around your business needs.

				p Local Support • Custom Design • Modern & Reliable
				

						
			
		section.servicesPage-boxes.container
		
			.servicePage--grid
		
				.servicePage--box
			
					.servicePage--box-heading--box
						.servicePage--box-heading--icon
							img(src="/img/icons/scroll.svg" class="servicesPage-icon" alt="scroll icon" , fetchpriority='high')
						.servicePage--box-heading--text
							h3.servicePage--box-heading One-Page Website

					.servicePage--box-details--box
						p.servicePage--box-details For small businesses that need a professional online presence without extra complexity.
						
						.servicePage--box-includes--box
						
							ul.servicePage--box-includes
								li Click-to-call + enquiry form
								li Clear services + service area
								li Looks great on phones
								
							.servicePage--included-btn--box 
								button.servicePage-included-btn(type='button') What’s included?

					.servicePage-included--box.box--inactive
						.servicePage-included--heading-box
							h3.servicePage-included--heading One-Page Website	
							.servicePage-included--close 
								button.servicePage-included-close(type='button' aria-label='Close included features') 
									p ×
							
						.servicePage-included--text
							p.servicePage-included--details For small businesses that need a professional online presence without extra complexity.
		
						
						.servicePage-included--list
							p This type of website may include:	
							ul.servicePage-included--ul
									li Contact form section
									li Click-to-call button
									li Services section
									li Service area section
									li About/business intro
									li Mobile-friendly layout	
			
				.servicePage--box
			
					.servicePage--box-heading--box
						.servicePage--box-heading--icon
							img(src="/img/icons/files.svg" class="servicesPage-icon" alt="files icon" , fetchpriority='high')
						.servicePage--box-heading--text
							h3.servicePage--box-heading Multi-Page Website

					.servicePage--box-details--box
						p.servicePage--box-details For businesses that offer multiple services or need more room to build trust.
						.servicePage--box-includes--box
							ul.servicePage--box-includes
								li Separate pages for each service
								li Stronger trust pages (About / FAQs)
								li Better search visibility
							.servicePage--included-btn--box 
								button.servicePage-included-btn(type='button') What’s included?
	
					.servicePage-included--box.box--inactive
						.servicePage-included--heading-box
							h3.servicePage-included--heading Multi-Page Website	
							.servicePage-included--close 
								button.servicePage-included-close(type='button' aria-label='Close included features') 
									p ×
						.servicePage-included--text
							p.servicePage-included--details For businesses that offer multiple services or need a more complete website to build trust online.
		
						
						.servicePage-included--list
							p This type of website may include:	
							ul.servicePage-included--ul
									li Separate service pages
									li Dedicated About page
									li FAQ or trust-building pages
									li Clear site navigation
									li Dedicated Contact page
									li Gallery or portfolio page
									li Stronger page structure for SEO
			
				
				.servicePage--box
		
					.servicePage--box-heading--box
						.servicePage--box-heading--icon
							img(src="/img/icons/database.svg" class="servicesPage-icon" alt="database icon" , fetchpriority='high')
						.servicePage--box-heading--text
							h3.servicePage--box-heading Advanced Website

					.servicePage--box-details--box
						p.servicePage--box-details For websites that need more than static pages, including dynamic content, saved information, and custom-built features.
						.servicePage--box-includes--box
							ul.servicePage--box-includes
								li Add and manage content
								li Secure data storage
								li Advanced built-in features							
							.servicePage--included-btn--box 
								button.servicePage-included-btn(type='button') What’s included?
							
					.servicePage-included--box.box--inactive
						.servicePage-included--heading-box
							h3.servicePage-included--heading Advanced Website	
							.servicePage-included--close 
								button.servicePage-included-close(type='button' aria-label='Close included features') 
									p ×
						.servicePage-included--text
							p.servicePage-included--details For websites that need more than static pages, including dynamic content, and custom-built features.
				
						
						.servicePage-included--list
							p This type of website may include:		
							ul.servicePage-included--ul
									li Admin-managed content
									li User accounts or logins
									li Search and filter features
									li Booking or request systems
									li Interactive user features
									li Saved enquiries or submissions
									li Custom-built functionality

		
		section.servicesPage-cta.container
			.servicesPage--link
				p.servicesPage--seo All websites include SEO foundations, mobile-friendly design, and fast loading.
				.servicesPage--link-pricing
					p.servicesPage--link-p Every business is different, so each custom-built website is quoted around the features and functionality you actually need.
			
			
				a.banner-cta(href="/static/contact") Get a Quick Quote ▶