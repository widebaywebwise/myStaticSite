
extends base

block content 

	main.servicesPage-block
	
		section.servicesPage
			
			.servicesPage-heading-box.container
				.servicesPage-heading-box-underline

					h1.servicesPage--heading Services
					hr.servicesPage-underline
				p Clean, fast websites built around your business needs.

				p Local Support • Built for You • Fast and Reliable
				

						
			
		section.servicesPage-boxes.container
		
			.servicePage--grid
				a.serviceCardLink(href="/static/contact#contact-form")
					.servicePage--box
				
						.servicePage--box-heading--box
							.servicePage--box-heading--icon
								img(src="/img/icons/scroll.svg" class="servicesPage-icon" alt="scroll icon" , fetchpriority='high')
							.servicePage--box-heading--text
								h3.servicePage--box-heading One-Page Website

						.servicePage--box-details--box
							p.servicePage--box-details For small businesses that need a professional online presence without extra complexity.
							ul.servicePage--box-includes
								li Click-to-call + enquiry form
								li Clear services + service area
								li Looks great on phones


			
				a.serviceCardLink(href="/static/contact#contact-form")
					.servicePage--box
				
						.servicePage--box-heading--box
							.servicePage--box-heading--icon
								img(src="/img/icons/files.svg" class="servicesPage-icon" alt="files icon" , fetchpriority='high')
							.servicePage--box-heading--text
								h3.servicePage--box-heading Multi-Page Website

						.servicePage--box-details--box
							p.servicePage--box-details For businesses that offer multiple services or need more room to build trust.
							ul.servicePage--box-includes
								li Separate pages for key services
								li Stronger trust pages (About / FAQs)
								li Better Google visibility

			
				a.serviceCardLink(href="/static/contact#contact-form")
					.servicePage--box
			
						.servicePage--box-heading--box
							.servicePage--box-heading--icon
								img(src="/img/icons/database.svg" class="servicesPage-icon" alt="database icon" , fetchpriority='high')
							.servicePage--box-heading--text
								h3.servicePage--box-heading Advanced Website

						.servicePage--box-details--box
							p.servicePage--box-details For websites that need more than static pages — including saved information and content that updates.
							ul.servicePage--box-includes
								li Editable content (services, pricing, posts)
								li Enquiries saved to a database
								li Optional upgrades like accounts or payments
								
		
		
		section.servicesPage-cta.container
			.servicesPage--link
				p.servicesPage--seo All websites include SEO foundations, mobile-friendly design, and fast loading.
				.servicesPage--link-pricing
					p.servicesPage--link-p Every business is different, so each website is quoted based on what you actually need.
			
			
				a.banner-cta(href="/static/contact") Get a Quick Quote ▶