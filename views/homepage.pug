
extends base

block content 

	main.homePage__main.med-container
	
		section.homePage__hero
		
			.homePage-grid.med-container
			
				.homePage__hero--text-box
					.homePage__hero--heading-block
			
						h1.homePage--heading Get Your Business Online with a
						.flex-heading
							p Professional 
							span Website
						
					p.homePage--sub-heading Your business needs a professional online presence that you own and control, one that shows up in search results and works for you around the clock.
					
					.homepPage-tagline
						.hopePage-tagline--box
							p No WordPress &middot; &nbsp;
						.hopePage-tagline--box
							p No templates &middot; &nbsp;
						.hopePage-tagline--box
							p Built for you

					.homePage__cta-box
						a(href="/static/contact" class='homePage__cta')  Take Your First Step ▶
						p No obligation — a quick chat to map out what you need.
					
				.homePage__hero--image-box
				
					.homePage__hero--img 
				
						img(src="/img/imgs/home.webp", alt="young man teaching senior man on a laptop", class='homePage__hero--img-image' , width='650' , height='537' ,fetchpriority='high')
						

		
		section.homePage__services 
			.services__heading-box 
				h2.section-heading How We Help You 
				
			.services__content-box 
				.homePage__services--grid 
					.homePage__services--grid-box 
						.services--icon-box
							img(src="/img/icons/magnifying-glass.svg", class='services-icon' alt="magnifying icon")
						.services--heading-box
							h3 Get Found on Google
						.services--text-box
							p Show up when locals search for what you do — and look more credible than competitors still relying on Facebook.
					.homePage__services--grid-box 
						.services--icon-box
							img(src="/img/icons/handshake.svg", class='services-icon' alt="handshake icon")
						.services--heading-box
							h3  Make a Great First Impression
						.services--text-box
							p A professional website builds trust before customers even pick up the phone.
					
					.homePage__services--grid-box 
						.services--icon-box
							img(src="/img/icons/shield-check.svg", class='services-icon' alt="shield with tick icon")
						.services--heading-box
							h3 Modern & Secure
						.services--text-box
							p Custom built code means no WordPress vulnerabilities, no plugin headaches, just a fast reliable site.
					
			//- hr.section-divider
				
		section.homePage__process
			.process__heading-box 
				h2 How It Works
				p A simple 3-step process to get your business online.
			 
			.process__steps#how-it-works
			
				.process__step--card
					.process__step-card--left
						.process__step--number 
							p 1
						.process__step--btn--box
							.process__step--icon 💬
							button.process__step--btn.btn-active(type="button" data-step="1") Have a Chat
					.process__step-card--right
						.process__step-text.process-step--1.content-active
							h3 We have a chat to establish your needs
							p.process__step--desc Tell us about your business, your goals, and who your customers are.
							p.process__step--desc No tech jargon — just a relaxed conversation about what you need.
							p.process__step--desc We'll talk through what pages you need, what you want people to do when they land on your site, and what makes your business different.

				.process__step--card
					.process__step-card--left
						.process__step--number 
							p 2
						.process__step--btn--box
							.process__step--icon 🛠️
							button.process__step--btn.btn-inactive(type="button" data-step="2") We Build It
					.process__step-card--right
						.process__step-text.process-step--2.content-hidden
							h3 We start the process of building you your website
							p.process__step--desc We design and build your custom site — no templates, no WordPress, no bloat.
							p.process__step--desc Clean code, fast loading, and built to rank on Google from day one.
							p.process__step--desc You'll see progress along the way and get the chance to give feedback before anything goes live.

				.process__step--card
					.process__step-card--left
						.process__step--number 
							p 3
						.process__step--btn--box
							.process__step--icon 🚀
							button.process__step--btn.btn-inactive(type="button" data-step="3") You Go Live
					.process__step-card--right
						.process__step-text.process-step--3.content-hidden
							h3 Launch Day — Your Site Goes Live
							p.process__step--desc We handle the launch, get you set up on Google Search Console, and make sure everything works perfectly.
							p.process__step--desc Your business is online and working for you 24/7 — no maintenance headaches, no WordPress updates to worry about.
							p.process__step--desc And we don't just disappear — we're local, so we're always easy to reach if you need anything.	
					
				 
		section.homePage__banner 
			.homepage__banner--wide-box
				h2 Wide Bay local — easy to reach, easy to work with.
				p.homePage__banner-sub-heading  Clear communication, regular updates, and a simple process from start to launch.
				p.homePage__banner-p No tech jargon — just friendly guidance and local support.
				p.homePage__banner-p-1 Bundaberg • Bargara • Hervey Bay • Maryborough
				.banner-cta-box
					a(href="/static/contact" , class='banner-cta') Get a Quick Quote
				
				
			