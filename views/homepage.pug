
extends base

block content 

	main.homePage__main.med-container
	
		section.homePage__hero
		
			.homePage-grid.med-container
			
				.homePage__hero--text-box
					.homePage__hero--heading-block
			
						h1.homePage--heading Get Your Business Online with a
						.flex-heading
							p Professional 
							span Website
						
					p.homePage--sub-heading Custom web design for local businesses across Bundaberg, Hervey Bay, Maryborough and the Wide Bay region.
					
					.homepPage-tagline
						.hopePage-tagline--box
							p Custom Websites &middot; &nbsp;
						.hopePage-tagline--box
							p Local Support &middot; &nbsp;
						.hopePage-tagline--box
							p Bundaberg Based

					.homePage__cta-box
						a(href="/static/contact" class='homePage__cta')  Take The First Step ▶
						p No obligation — just a quick chat to see what you need.
					
				.homePage__hero--image-box
				
					.homePage__hero--img 
				
						img(src="/img/imgs/home.webp", alt="young man teaching senior man on a laptop", class='homePage__hero--img-image' , width='650' , height='537' ,fetchpriority='high')
						

		
		section.homePage__services 
			.services__heading-box 
				h2.section-heading.section__heading-underline How We Help You 
				
			.services__content-box 
				.homePage__services--grid 
					.homePage__services--grid-box 
						.services--icon-box
							img(src="/img/icons/magnifying-glass.svg", class='services-icon' alt="magnifying icon")
						.services--heading-box
							h3 Search-Friendly Websites
						.services--text-box
							p Built to make your business easier to find online and more trustworthy from the first click.
					.homePage__services--grid-box 
						.services--icon-box
							img(src="/img/icons/layout.svg", class='services-icon' alt="layout icon")
						.services--heading-box
							h3  Professional Web Design
						.services--text-box
							p A clean, modern website helps your business look more established, credible,  and professional online.
					
					.homePage__services--grid-box 
						.services--icon-box
							img(src="/img/icons/shield-check.svg", class='services-icon' alt="shield with tick icon")
						.services--heading-box
							h3 Modern & Secure
						.services--text-box
							p Modern, secure websites built for a professional online presence and a reliable user experience.
					
			//- hr.section-divider

				 
		section.homePage__process
			.process__heading-box
				h2.section-heading.section__heading-underline How It Works
				p A simple 3-step process to get your business online.

			.process__box
				.process__step
					.process__step-number 1
					.process__step-content
						h3 Have a Chat
						p.process__step-lead We start with a simple conversation about your business, your goals, and what you want your website to do.
						p.process__step-desc No jargon — just a clear, practical chat about the right direction.
					.process__step-arrow 
						.process__step-arrow--icon
							img(src="/img/icons/arrow-right-org.svg", class='services-icon' alt="shield with tick icon")

				.process__step
					.process__step-number 2
					.process__step-content
						h3 We Build It
						p.process__step-lead Your website is designed and built around your business, the pages you need, and the actions you want customers to take.
						p.process__step-desc The goal is a website that looks professional, feels easy to use, and supports your business.
					.process__step-arrow 
						.process__step-arrow--icon
							img(src="/img/icons/arrow-right-org.svg", class='services-icon' alt="shield with tick icon")

				.process__step
					.process__step-number 3
					.process__step-content
						h3 You Go Live
						p.process__step-lead Your website goes live and is ready for customers to find and use.
						p.process__step-desc You’ll have a professional online presence in place, with support there when you need it.

		section.homePage__banner 
			.homepage__banner--wide-box
				h2 Wide Bay local — practical and professional.
				p.homePage__banner-sub-heading  Clear communication and a simple path from enquiry to launch.
				p.homePage__banner-p No pressure and no confusing tech talk — just honest advice and local support.
				p.homePage__banner-p-1 Bundaberg • Bargara • Hervey Bay • Maryborough
				.banner-cta-box
					a(href="/static/contact" , class='banner-cta') Get a Quick Quote
				
				
			