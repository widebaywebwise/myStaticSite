extends base 



block content

	main.container
	
		section.contact
			
			.contact-heading-box
			
				.contact-heading-box-underline

					h2.servicesPage--heading Get In Touch
					hr.contact-underline
					
				.contact-text-box
					p Thinking about getting a website for your business? Fill out the form below and share a few details about what you need.

				
			.contact-form-box
			
				.contact-form-grid
				
					.contact-form--img--box
						img(src="/img/imgs/form-img.webp", alt="web development environment with monitors and keyboard" , class='contact-form--img', fetchpriority='high')
					
					.contact-form--form
					
						form#contact--form(action="/api/v1/enquiries" method="POST" class='contact-form')
							if rateLimitError
								p.contact-form__error= rateLimitError
							.contact-form--row 
								label(for="name") Your Name 
								input(type="text" name='name' id='name' required)
								
							.contact-form--row 
								label(for="email") Email Address
								input(type="email" name='email' id='email' required) 
								
							.contact-form--row 
								label(for="phone") Phone Number (Optional)
								input(type="tel" name='phone' id='phone')
							
							.contactPage__form-row.contactPage__honeypot(aria-hidden="true")
								label(for="website") Website
								input(type="text" name="website" id="website" tabindex="-1" autocomplete="off")
								
															
							.contact-form--row 
								label(for="enquiry") Enquiry Type
								select#enquiry(name="enquiry" required)
									option(value="" disabled selected) Select an enquiry type
									option(value="general-enquiry") General enquiry
									option(value="quick-quote") Get a quick quote
									option(value="new-website") New website
									option(value="simple-business-website") Simple business website
									option(value="online-store") Online store
									option(value="booking-enquiry-website") Booking / enquiry website
									option(value="not-sure-yet") Not sure yet
							
							.contact-form--row 
								label(for="message" id='message-label') Message
								textarea#message(name="message" maxlength="1000"  minlength="10"  rows="6" cols='52' placeholder="Tell us a little about your business and what you need..." required)
							
							.contact-form--submit-btn 
								button(type='submit' , class='contact-form--btn') Send Enquiry
														 

							.contact-form-bottom 
								p No obligation — just a clear reply and helpful advice on the best next step.
				
			